    "build": "npm run gov-images && node esbuild.config.js",
    "watch": "npm run gov-images && node esbuild.config.js --watch"
  },
  "engines": {
    "node": ">= 24.18.0",
    "npm": ">= 11.16.0"
  },
  "dependencies": {
    "@ministryofjustice/frontend": "^9.0.0",
    "govuk-frontend": "^6.4.0",
    "moment": "^2.30.1"
  },
  "devDependencies": {
    "esbuild": ">= 0.28.1",
    "esbuild-sass-plugin": ">= 3.7.0"
  },
  "overrides": {
    "picomatch": "4.0.4"
  }
}
